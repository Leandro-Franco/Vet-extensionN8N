{
  "manifest_version": 3,
  "name": "VetSmart — SimplesVet para n8n",
  "version": "1.0.0",
  "description": "Captura dados de atendimento clínico no SimplesVet e envia para n8n.",
  "icons": {
    "16": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://app.simples.vet/*",
    "https://n8n-n8n.stlrvo.easypanel.host/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.simples.vet/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "logo.png",
    "default_popup": "popup.html",
    "default_title": "VetSmart — Configurações"
  }
}
